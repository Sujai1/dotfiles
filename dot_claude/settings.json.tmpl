{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{ .chezmoi.homeDir }}/.claude/scripts/log_prompt.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 {{ .chezmoi.homeDir }}/.claude/scripts/context_reminder.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash {{ .chezmoi.homeDir }}/.claude/scripts/auto_git.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pip freeze > requirements.lock.txt 2>/dev/null && conda env export --no-builds > environment.yml 2>/dev/null; echo 'Updated requirements.lock.txt and environment.yml'",
            "if": "Bash(pip install*)",
            "statusMessage": "Updating package lock files",
            "async": true
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
